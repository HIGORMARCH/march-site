# ============================================================
# March Contabilidade — configuração de hospedagem (Apache / HostGator)
# ============================================================

# --- Charset padrão ---
AddDefaultCharset UTF-8

# --- Página de erro personalizada ---
ErrorDocument 404 /404.html

# --- Não listar conteúdo de pastas (segurança) ---
Options -Indexes

# --- Proteger arquivos sensíveis ---
<FilesMatch "(^\.htaccess|\.md|\.docx|\.json)$">
  Require all denied
</FilesMatch>

# ============================================================
# HTTPS + domínio canônico (sem www)
# ============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Força HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Redireciona www -> sem www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# ============================================================
# Cabeçalhos de segurança
# ============================================================
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS — só atua após o HTTPS estar ativo
  Header always set Strict-Transport-Security "max-age=15552000" env=HTTPS
</IfModule>

# ============================================================
# Compressão (GZIP)
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# ============================================================
# Cache do navegador
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
